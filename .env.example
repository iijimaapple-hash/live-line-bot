# LINEチャネル設定
LINE_ACCESS_TOKEN=再発行したアクセストークンをここに入力
LINE_CHANNEL_SECRET=Channel secretをここに入力

# LIFFフォームのURL（GitHub PagesのURL）
LIFF_URL=https://iijimaapple-hash.github.io/liff-estimate/

# GAS WebアプリのURL（スプレッドシート記録・メール通知用）
GAS_URL=https://script.google.com/macros/s/xxxxxxxx/exec

# ポート番号（Renderが自動設定するので変更不要）
PORT=3000
